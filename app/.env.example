# Vite loads env from the repository root (.env next to the `app` folder) OR from this folder.
# Prefer: copy ../.env.example to ../.env at repo root and edit there.
# Supabase: Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key

# Require email verification: Authentication → Providers → Email → Confirm email (enable)
